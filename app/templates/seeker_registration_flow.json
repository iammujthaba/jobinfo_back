{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "SEEKER_REGISTRATION": ["SEEKER_LOCATION"],
    "SEEKER_LOCATION": []
  },
  "screens": [
    {
      "id": "SEEKER_REGISTRATION",
      "title": "Job Seeker Registration",
      "terminal": false,
      "data": {
        "pending_job_code": {
          "type": "string",
          "__example__": "JC1001"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "registration_form",
            "children": [
              {
                "type": "TextInput",
                "name": "name",
                "label": "Full Name",
                "input-type": "text",
                "required": true,
                "helper-text": "Enter your full name"
              },
              {
                "type": "TextInput",
                "name": "pin_code",
                "label": "PIN Code",
                "input-type": "number",
                "required": true,
                "helper-text": "Your 6-digit area PIN code (e.g. 673014)",
                "min-chars": 6,
                "max-chars": 6
              },
              {
                "type": "Dropdown",
                "name": "category",
                "label": "Preferred Job Area",
                "required": true,
                "data-source": [
                  {"id": "retail", "title": "Retail & Showrooms"},
                  {"id": "hospitality", "title": "Hospitality & Food Service"},
                  {"id": "healthcare", "title": "Healthcare & Caretaking"},
                  {"id": "driving", "title": "Driving & Logistics"},
                  {"id": "office_admin", "title": "Office & Admin"},
                  {"id": "maintenance_technician", "title": "Maintenance & Technician"},
                  {"id": "it_professional", "title": "IT & Professional"},
                  {"id": "gulf_abroad", "title": "Gulf / Abroad Jobs"},
                  {"id": "other", "title": "Other / General"}
                ]
              },
              {
                "type": "DocumentPicker",
                "name": "cv_file",
                "label": "Upload CV (PDF)",
                "max-uploaded-documents": 1,
                "max-file-size-kb": 5120
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Next",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "name": "${form.name}",
                "pin_code": "${form.pin_code}",
                "category": "${form.category}",
                "cv_file": "${form.cv_file}",
                "pending_job_code": "${data.pending_job_code}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SEEKER_LOCATION",
      "title": "Final Details",
      "terminal": true,
      "data": {
        "post_offices": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [
            { "id": "Thondayad", "title": "Thondayad" },
            { "id": "Kozhikode H.O", "title": "Kozhikode H.O" }
          ]
        },
        "sub_categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [
            { "id": "sales_executive", "title": "Sales Executive" },
            { "id": "cashier", "title": "Cashier / Billing" }
          ]
        },
        "api_failed": {
          "type": "boolean",
          "__example__": false
        },
        "api_success": {
          "type": "boolean",
          "__example__": true
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "location_form",
            "children": [
              {
                "type": "Dropdown",
                "name": "sub_category",
                "label": "Select Preferred Role",
                "required": true,
                "data-source": "${data.sub_categories}"
              },
              {
                "type": "Dropdown",
                "name": "post_office",
                "label": "Select Nearby Location",
                "required": true,
                "visible": "${data.api_success}",
                "data-source": "${data.post_offices}"
              },
              {
                "type": "TextInput",
                "name": "manual_location_input",
                "label": "Type Preferred Job Location",
                "input-type": "text",
                "required": true,
                "visible": "${data.api_failed}",
                "helper-text": "E.g. Kozhikode, Kochi"
              },
              {
                "type": "TextInput",
                "name": "age",
                "label": "Your Age",
                "input-type": "number",
                "required": true,
                "helper-text": "E.g., 25, 30, 35",
                "max-chars": 2
              },
              {
                "type": "TextInput",
                "name": "alt_phone",
                "label": "Alternative contact Number",
                "input-type": "phone",
                "required": false,
                "helper-text": "Leave blank if WhatsApp is your contact number"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Submit Registration",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "post_office": "${form.post_office}",
                "manual_location_input": "${form.manual_location_input}",
                "sub_category": "${form.sub_category}",
                "age": "${form.age}",
                "alt_phone": "${form.alt_phone}",
                "category": "${screen.SEEKER_REGISTRATION.form.category}",
                "name": "${screen.SEEKER_REGISTRATION.form.name}",
                "pin_code": "${screen.SEEKER_REGISTRATION.form.pin_code}",
                "media_id": "${screen.SEEKER_REGISTRATION.form.cv_file}",
                "mime_type": "application/pdf",
                "pending_job_code": "${screen.SEEKER_REGISTRATION.data.pending_job_code}"
              }
            }
          }
        ]
      }
    }
  ]
}